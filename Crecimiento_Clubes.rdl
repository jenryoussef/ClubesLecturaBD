            <rd:UserDefined>true</rd:UserDefined>
            <Value>=Parameters!AnioSeleccionado.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT pais, anio, club, crecimiento 
FROM REPORTE_ADFJ_V_CRECIMIENTO_MIEMBROS
WHERE anio = :AnioSeleccionado</CommandText>
      </Query>
