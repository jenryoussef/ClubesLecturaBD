  <DataSets>
    <DataSet Name="ds_listalibros">
      <Query>
        <DataSourceName>proyecto</DataSourceName>
        <CommandText>SELECT DISTINCT "ISBN", "TITULO"
FROM v_reporte_libros_grupos
ORDER BY "TITULO" ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="ISBN">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>ISBN</DataField>
        </Field>
        <Field Name="TITULO">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TITULO</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ds_gruposanalisis">
