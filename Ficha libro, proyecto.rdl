            <Value>=Parameters!p_isbn.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT * FROM v_reporte_libros_grupos
WHERE "ISBN" = :p_isbn</CommandText>
      </Query>
