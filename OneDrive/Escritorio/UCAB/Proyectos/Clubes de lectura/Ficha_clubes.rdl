            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="Ubicación: " &amp; First(Fields!DIRECCION.Value, "CLUBES") &amp; 
", Zona Postal: " &amp; First(Fields!ZONA_POSTAL.Value, "CLUBES") &amp; 
", " &amp; First(Fields!CIUDAD.Value, "CLUBES") &amp; 
IIF(IsNothing(First(Fields!PAIS.Value, "CLUBES")), "", " - " &amp; REPLACE(First(Fields!PAIS.Value, "CLUBES"), "ESPA?A", "ESPAÑA")) &amp; 
VbCrLf &amp; "Idioma oficial: " &amp; REPLACE(First(Fields!IDIOMAS_CLUB.Value, "CLUBES"), "ESPA?OL", "ESPAÑOL")</Value>
                    <Style>
                      <FontSize>12pt</FontSize>
