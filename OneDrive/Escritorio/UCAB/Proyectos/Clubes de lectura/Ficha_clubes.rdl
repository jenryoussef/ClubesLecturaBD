  <DataSources>
    <DataSource Name="ClubesDeLectura">
      <rd:SecurityType>DataBase</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>ODBC</DataProvider>
        <ConnectString>Driver={Oracle in instantclient_23_0};Dbq=localhost:1521/xe;</ConnectString>
      </ConnectionProperties>
      <rd:DataSourceID>420df694-981d-4953-b4e5-ba85b05602f6</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="CLUBES">
      <Query>
        <DataSourceName>ClubesDeLectura</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="?">
            <Value>=Parameters!PARAMETRO1.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    g.id_grupo AS NRO_GRUPO,
    g.tipo AS TIPO,
    g.dia AS DIA,
    TO_CHAR(g.hora, 'HH24:MI') AS HORA,
    g.id_club AS ID_CLUB,
    c.nombre AS NOMBRE,
    c.direccion AS DIRECCION,
    c.cod_postal AS ZONA_POSTAL,
    ciu.nombre AS CIUDAD,
    p.nombre AS PAIS,
    (SELECT NVL(LISTAGG(i.nombre, ', ') WITHIN GROUP (ORDER BY i.nombre), 'No especificado')
     FROM ADFJ_Habla h, ADFJ_Idiomas i
     WHERE h.id_idioma = i.id_idioma
       AND h.id_club = c.id_club) AS IDIOMAS_CLUB
FROM 
    ADFJ_Grupos_Lectura g,
    ADFJ_Clubes c,
    ADFJ_Ciudades ciu,
    ADFJ_Paises p
WHERE 
    g.id_club = c.id_club
    
    AND c.id_pais   = ciu.id_pais (+)
    AND c.id_ciudad = ciu.id_ciudad (+)
    AND c.id_pais   = p.id_pais (+)
    AND g.id_club = ?</CommandText>
      </Query>
      <Fields>
        <Field Name="NRO_GRUPO">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>NRO_GRUPO</DataField>
        </Field>
        <Field Name="TIPO">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TIPO</DataField>
        </Field>
        <Field Name="DIA">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>DIA</DataField>
        </Field>
        <Field Name="HORA">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>HORA</DataField>
        </Field>
        <Field Name="ID_CLUB">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ID_CLUB</DataField>
        </Field>
        <Field Name="NOMBRE">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>NOMBRE</DataField>
        </Field>
        <Field Name="DIRECCION">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DIRECCION</DataField>
        </Field>
        <Field Name="ZONA_POSTAL">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ZONA_POSTAL</DataField>
        </Field>
        <Field Name="CIUDAD">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>CIUDAD</DataField>
        </Field>
        <Field Name="PAIS">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>PAIS</DataField>
        </Field>
        <Field Name="IDIOMAS_CLUB">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>IDIOMAS_CLUB</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="LIBROS_CLUBES">
      <Query>
        <DataSourceName>ClubesDeLectura</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="?">
            <Value>=Parameters!PARAMETRO1.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    l.titulo AS TITULO_LIBRO,
    AVG(r.valoracion) AS VALORACION_PROMEDIO
FROM 
    ADFJ_Cal_Reuniones r,
    ADFJ_Libros l
WHERE 
    r.ISBN = l.ISBN
    AND r.id_club = ? 
    AND r.realizada = 'S'
GROUP BY 
    l.titulo
ORDER BY 
    VALORACION_PROMEDIO DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="TITULO_LIBRO">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TITULO_LIBRO</DataField>
        </Field>
        <Field Name="VALORACION_PROMEDIO">
          <rd:TypeName>System.Double</rd:TypeName>
          <DataField>VALORACION_PROMEDIO</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Lectores">
      <Query>
        <DataSourceName>ClubesDeLectura</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="?">
            <rd:UserDefined>true</rd:UserDefined>
            <Value>=Parameters!PARAMETRO1.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    c.id_club AS ID_CLUB,
    c.nombre AS NOMBRE_CLUB,
    m.id_lector AS ID_LECTOR,
    l.doc_identidad AS CEDULA,
    l.primer_nombre || ' ' || NVL(l.segundo_nombre, '') || ' ' || l.primer_apellido || ' ' || l.segundo_apellido AS NOMBRE_COMPLETO,
    m.f_ing_club AS FECHA_INGRESO
FROM 
    ADFJ_CLUBES c,
    ADFJ_HIST_MEMBRESIAS m,
    ADFJ_LECTORES l
WHERE 
    c.id_club = m.id_club
    AND m.id_lector = l.id_lector
    AND c.id_club = ?
ORDER BY 
    NOMBRE_COMPLETO ASC</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_CLUB">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ID_CLUB</DataField>
        </Field>
        <Field Name="NOMBRE_CLUB">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>NOMBRE_CLUB</DataField>
        </Field>
        <Field Name="ID_LECTOR">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>ID_LECTOR</DataField>
        </Field>
        <Field Name="CEDULA">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>CEDULA</DataField>
        </Field>
        <Field Name="NOMBRE_COMPLETO">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>NOMBRE_COMPLETO</DataField>
        </Field>
        <Field Name="FECHA_INGRESO">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>FECHA_INGRESO</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
