          <DataField>NOMBRE_LECTOR</DataField>
        </Field>
        <Field Name="F_ING_CLUB">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>F_ING_CLUB</DataField>
        </Field>
        <Field Name="TIPO">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TIPO</DataField>
        </Field>
        <Field Name="ID_GRUPO">
          <rd:TypeName>System.Int16</rd:TypeName>
          <DataField>ID_GRUPO</DataField>
        </Field>
      </Fields>
