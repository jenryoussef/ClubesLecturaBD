    <DataSet Name="Lectores">
      <Query>
        <DataSourceName>ClubesDeLectura</DataSourceName>
        <QueryParameters>
          <QueryParameter Name=":nombre">
            <Value>=Parameters!PARAMETRO1.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>Select id_lector, cedula, nombre_lector, f_ing_club, tipo, id_grupo
FROM ADFJ_V_LECTORES_GRUPOS
Where F_FIN_GRUPO is NULL
	AND nombre_club = :nombre
ORDER BY 
    tipo, id_grupo, nombre_lector</CommandText>
      </Query>
      <Fields>
        <Field Name="ID_LECTOR">
          <rd:TypeName>System.Int16</rd:TypeName>
          <DataField>ID_LECTOR</DataField>
        </Field>
        <Field Name="CEDULA">
