  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Textbox Name="Textbox3">
            <rd:DefaultName>Textbox3</rd:DefaultName>
            <CanGrow>true</CanGrow>
            <KeepTogether>true</KeepTogether>
            <Paragraphs>
              <Paragraph>
                <TextRuns>
                  <TextRun>
                    <Value>="Ubicación: " &amp; First(Fields!DIRECCION.Value, "CLUBES") &amp; 
", Zona Postal: " &amp; StrConv(First(Fields!ZONA_POSTAL.Value, "CLUBES"), 3) &amp; 
", " &amp; StrConv(First(Fields!CIUDAD.Value, "CLUBES"), 3) &amp; 
IIF(IsNothing(First(Fields!PAIS.Value, "CLUBES")), "", " - " &amp; StrConv(REPLACE(First(Fields!PAIS.Value, "CLUBES"), "ESPA?A", "ESPAÑA"), 3))</Value>
                    <Style>
                      <FontSize>12pt</FontSize>
                    </Style>
                  </TextRun>
                </TextRuns>
                <Style>
                  <TextAlign>Center</TextAlign>
