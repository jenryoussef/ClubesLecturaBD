    <DataSet Name="secuencia_lectura">
      <Query>
        <DataSourceName>proyecto</DataSourceName>
        <QueryParameters>
          <QueryParameter Name=":titulo">
            <Value>=Parameters!titulo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT isbn, titulo, To_char(ano_publicacion, 'yyyy') as anio
FROM adfj_libros
CONNECT BY PRIOR isbn = id_anterior
START WITH isbn IN (
    SELECT isbn 
    FROM adfj_libros
    WHERE id_anterior IS NULL 
    START WITH titulo = :titulo
    CONNECT BY PRIOR id_anterior = isbn
)
ORDER SIBLINGS BY ano_publicacion</CommandText>
      </Query>
      <Fields>
        <Field Name="ISBN">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>ISBN</DataField>
        </Field>
        <Field Name="TITULO">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TITULO</DataField>
        </Field>
        <Field Name="ANIO">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ANIO</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
